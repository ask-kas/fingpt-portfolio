# =============================================
# COPY THIS FILE:  cp .env.example .env
# Then fill in your real keys in .env
# .env is git-ignored and will NOT be pushed
# =============================================

# Alpha Vantage (free key: https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_key_here

# FRED (free key: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_key_here

# SEC EDGAR (no key needed, just identify yourself)
SEC_USER_AGENT=YourName your_email@example.com

# ngrok auth token (free: https://dashboard.ngrok.com/signup)
NGROK_AUTH_TOKEN=your_token_here

# Hugging Face token (for gated Llama2 model access)
# Get it at https://huggingface.co/settings/tokens
# You must also accept the Llama2 license at https://huggingface.co/meta-llama/Llama-2-7b-chat-hf
HF_TOKEN=your_token_here

# Colab Model URL — filled in AFTER you run the Colab notebook
# It will print something like https://xxxx-xx-xx.ngrok-free.app
COLAB_MODEL_URL=http://localhost:5000
