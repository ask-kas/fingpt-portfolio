# =============================================
# COPY THIS FILE:  cp config/.env.example config/.env
# Then fill in your real keys below.
# config/.env is git-ignored and will NOT be pushed.
# =============================================

# FRED API (free: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_key_here

# SEC EDGAR (no key needed, just identify yourself per fair access policy)
SEC_USER_AGENT=YourName your_email@example.com

# ngrok auth token (free: https://dashboard.ngrok.com/signup)
NGROK_AUTH_TOKEN=your_token_here

# Hugging Face token (for gated Llama-2 model access)
# Get it at https://huggingface.co/settings/tokens
# You must also accept the Llama-2 license at:
# https://huggingface.co/meta-llama/Llama-2-7b-chat-hf
HF_TOKEN=your_token_here

# Colab Model URL — updated AFTER you run the Colab notebook
# The notebook prints an ngrok URL like https://xxxx-xx-xx.ngrok-free.app
COLAB_MODEL_URL=http://localhost:5000

# Admin key — required to promote users via /api/db/admin/promote
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=

# ── In-app AI chat (Veris assistant) ─────────────────────────
# Powers the chat panel in the dashboard ("Veris AI"). Uses
# gemini-2.5-flash with function-calling over the local MCP volatility
# tools and (optionally) the NYU V-Lab MCP server.
#
# Get a free key at https://aistudio.google.com/apikey
#   1. Sign in with a Google account
#   2. Click "Create API key" → copy the value (starts with "AIza...")
#   3. Paste below. Free tier is generous; no billing required.
#
# Without this key, /api/chat returns 503 and the chat panel shows an
# error. The rest of the dashboard works fine without it.
GEMINI_API_KEY=

# ── NYU V-Lab MCP bridge (optional) ──────────────────────────
# https://vlab.stern.nyu.edu/mcp exposes Robert Engle's institutional-
# grade volatility analytics over MCP. The endpoint requires OAuth,
# so the backend wraps it via `npx -y mcp-remote <url>` which:
#   • Spawns a stdio MCP bridge to V-Lab
#   • Opens a browser tab for OAuth on first call
#   • Caches the token in ~/.mcp-auth/ so subsequent calls are silent
#
# Prerequisites:
#   • Node.js installed (https://nodejs.org) so `npx` is on PATH
#   • A V-Lab login (free signup at https://vlab.stern.nyu.edu)
#
# First-run flow: send a chat message, watch the backend's terminal
# stderr for an "Open this URL to authorize" line, complete the
# login. The token is then cached and reused for ~24 hours.
#
# Set VLAB_DISABLED=1 to skip V-Lab entirely (chat will use only the
# local yfinance-derived volatility tools). Recommended if you don't
# want to do the OAuth dance or don't have Node.js installed.
VLAB_DISABLED=1
# VLAB_MCP_URL=https://vlab.stern.nyu.edu/mcp
# VLAB_DISCOVERY_TIMEOUT=12   # seconds before we give up on tool discovery
# VLAB_CALL_TIMEOUT=30        # seconds before we give up on a tool call

# ── Database ─────────────────────────────────────────────────
# Option 1: Full DATABASE_URL (takes priority if set)
# DATABASE_URL=sqlite:///./data/veris.db
# DATABASE_URL=mysql+pymysql://user:password@host:3306/veris
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/veris

# Option 2: Individual vars (MySQL/PostgreSQL)
# DB_HOST=localhost
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_NAME=veris
# DB_PORT=3306
# DB_DRIVER=mysql+pymysql

# Set to "true" to log all SQL queries (debug only)
# DB_ECHO=false
