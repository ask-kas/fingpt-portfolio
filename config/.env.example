# =============================================
# COPY THIS FILE:  cp config/.env.example config/.env
# Then fill in your real keys below.
# config/.env is git-ignored and will NOT be pushed.
# =============================================

# FRED API (free: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_key_here

# SEC EDGAR (no key needed, just identify yourself per fair access policy)
SEC_USER_AGENT=YourName your_email@example.com

# ngrok auth token (free: https://dashboard.ngrok.com/signup)
NGROK_AUTH_TOKEN=your_token_here

# Hugging Face token (for gated Llama-2 model access)
# Get it at https://huggingface.co/settings/tokens
# You must also accept the Llama-2 license at:
# https://huggingface.co/meta-llama/Llama-2-7b-chat-hf
HF_TOKEN=your_token_here

# Colab Model URL — updated AFTER you run the Colab notebook
# The notebook prints an ngrok URL like https://xxxx-xx-xx.ngrok-free.app
COLAB_MODEL_URL=http://localhost:5000
